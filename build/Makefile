# Alternative GNU Make workspace makefile autogenerated by Premake

ifndef config
  config=debug
endif

ifndef verbose
  SILENT = @
endif

ifeq ($(config),debug)
  GLFW_config = debug
  limbo_config = debug
  gtest_config = debug
  tests_config = debug

else ifeq ($(config),release)
  GLFW_config = release
  limbo_config = release
  gtest_config = release
  tests_config = release

else
  $(error "invalid configuration $(config)")
endif

PROJECTS := GLFW limbo gtest tests

.PHONY: all clean help $(PROJECTS) 

all: $(PROJECTS)

GLFW:
ifneq (,$(GLFW_config))
	@echo "==== Building GLFW ($(GLFW_config)) ===="
	@${MAKE} --no-print-directory -C . -f GLFW.make config=$(GLFW_config)
endif

limbo: GLFW
ifneq (,$(limbo_config))
	@echo "==== Building limbo ($(limbo_config)) ===="
	@${MAKE} --no-print-directory -C . -f limbo.make config=$(limbo_config)
endif

gtest:
ifneq (,$(gtest_config))
	@echo "==== Building gtest ($(gtest_config)) ===="
	@${MAKE} --no-print-directory -C . -f gtest.make config=$(gtest_config)
endif

tests: limbo gtest
ifneq (,$(tests_config))
	@echo "==== Building tests ($(tests_config)) ===="
	@${MAKE} --no-print-directory -C . -f tests.make config=$(tests_config)
endif

clean:
	@${MAKE} --no-print-directory -C . -f GLFW.make clean
	@${MAKE} --no-print-directory -C . -f limbo.make clean
	@${MAKE} --no-print-directory -C . -f gtest.make clean
	@${MAKE} --no-print-directory -C . -f tests.make clean

help:
	@echo "Usage: make [config=name] [target]"
	@echo ""
	@echo "CONFIGURATIONS:"
	@echo "  debug"
	@echo "  release"
	@echo ""
	@echo "TARGETS:"
	@echo "   all (default)"
	@echo "   clean"
	@echo "   GLFW"
	@echo "   limbo"
	@echo "   gtest"
	@echo "   tests"
	@echo ""
	@echo "For more information, see https://github.com/premake/premake-core/wiki"